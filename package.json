{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:standalone": "node --env-file=.env .next/standalone/server.js",
    "lint": "eslint",
    "bootstrap:pg": "bash scripts/bootstrap-pg.sh",
    "bootstrap:host": "tsx scripts/bootstrap-shared-host.ts",
    "db:push": "node --env-file=.env node_modules/drizzle-kit/bin.cjs push",
    "db:seed": "node --env-file=.env --import tsx src/db/seed.ts",
    "db:studio": "node --env-file=.env node_modules/drizzle-kit/bin.cjs studio",
    "bot-runtime:build": "docker build -t sovereign-bot-runtime:dev bot-runtime",
    "docker:dev": "docker compose up -d postgres",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.10.0",
    "@base-ui/react": "^1.3.0",
    "@linode/api-v4": "^0.149.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.44.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "node-ssh": "^13.2.1",
    "otplib": "^12.0.1",
    "pg": "^8.13.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "stripe": "^17.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
