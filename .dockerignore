# Version control
.git
.gitignore

# Node / Next build outputs
node_modules
.next
out
dist

# Local databases — never copy SQLite into image
prisma/dev.db
prisma/dev.db-journal
prisma/*.db
prisma/*.db-*
prisma/dev.db.backup-*

# Env files — passed in at runtime, not baked into image
.env
.env.local
.env.development
.env.production
.env*.local

# IDE / OS
.vscode
.idea
.DS_Store
*.swp

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage
.nyc_output

# The bot-runtime has its own separate image — don't ship its source
bot-runtime

# Docs & infrastructure meta
README.md
*.md
docker-compose*.yml
Dockerfile
.dockerignore
