# ─── Database ────────────────────────────────────────────────────
# PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public&connection_limit=10&pool_timeout=30"
#
# SQLite (local dev only — requires reverting schema.prisma provider):
# DATABASE_URL="file:./dev.db"
DATABASE_URL="postgresql://sovereignml:password@localhost:5432/sovereignml_dev?schema=public"

# ─── NextAuth ────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET=""
AUTH_TRUST_HOST=true

# ─── Google OAuth (optional) ─────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_YEARLY=""

# ─── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@sovereignml.com"

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# ─── Instance Encryption (32-byte base64) ────────────────────────
# Generate with: openssl rand -base64 32
INSTANCE_ENCRYPTION_KEY=""

# ─── Bot Factory: LLM provider ───────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# ─── Bot Factory: Linode (VPS provisioning + shared host fleet) ──
# Personal Access Token from https://cloud.linode.com/profile/tokens
# Needs scopes: linodes:read_write, stackscripts:read_write
LINODE_API_TOKEN=""

# ─── Bot Factory: SSH fleet key ──────────────────────────────────
# Generate with:
#   ssh-keygen -t ed25519 -f ./sovereign_fleet -N ""
#   echo "SSH_FLEET_PRIVATE_KEY=\"$(cat ./sovereign_fleet | base64)\""
#   echo "SSH_FLEET_PUBLIC_KEY=\"$(cat ./sovereign_fleet.pub)\""
# (then delete the local files — they live in env only)
SSH_FLEET_PRIVATE_KEY=""
SSH_FLEET_PUBLIC_KEY=""

# ─── Bot Factory: Runtime image (GHCR) ───────────────────────────
# Built+pushed by .github/workflows/bot-runtime.yml
BOT_RUNTIME_IMAGE="ghcr.io/sovereignml/sovereign-bot-runtime:latest"

# ─── Bot Factory: Gateway base URL ───────────────────────────────
# In dev, point at your dev server. In prod, your real public URL.
NEXT_PUBLIC_GATEWAY_BASE_URL="http://localhost:3002"

# ─── Bot Factory: Optional external orchestrator (future hook) ───
# Leave unset to use built-in SSH-based provisioner.
OPENCLAW_ORCHESTRATOR_URL=""

# ─── Bot Factory: Telegram dev tunnel (optional) ─────────────────
# Telegram requires public HTTPS for webhooks. For dev, use ngrok and put
# its public URL here so we register the webhook against a real address.
# If unset, Telegram interface binding will save the token but skip webhook setup.
TELEGRAM_DEV_PUBLIC_URL=""
