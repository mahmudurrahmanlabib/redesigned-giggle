# Copy to .env.production on the VPS. Never commit the real file.
#   cp .env.production.example .env.production
#   # fill in real values
#   chmod 600 .env.production

# ─── Postgres (consumed by docker-compose) ──────────────────────────────
POSTGRES_USER=sovereignml
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=sovereignml

# Set to "true" on first boot only to seed regions/plans/admin user.
SEED_ON_BOOT=false

# ─── App env (consumed by Next.js inside the container) ─────────────────
# DATABASE_URL is overridden by docker-compose.yml — don't set it here.
NEXTAUTH_URL=https://sovereignml.com
NEXTAUTH_SECRET=
AUTH_TRUST_HOST=true

NEXT_PUBLIC_APP_URL=https://sovereignml.com
NEXT_PUBLIC_GATEWAY_BASE_URL=https://sovereignml.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ENTERPRISE_MONTHLY=
STRIPE_PRICE_ENTERPRISE_YEARLY=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@sovereignml.com

# Instance encryption (openssl rand -base64 32)
INSTANCE_ENCRYPTION_KEY=

# Bot Factory — LLM provider
OPENROUTER_API_KEY=

# Bot Factory — Linode provisioning
LINODE_API_TOKEN=
SSH_FLEET_PRIVATE_KEY=
SSH_FLEET_PUBLIC_KEY=

# Bot runtime image (deployed from .github/workflows/bot-runtime.yml)
BOT_RUNTIME_IMAGE=ghcr.io/sovereignml/sovereign-bot-runtime:latest

# Admin seed credentials (only used if SEED_ON_BOOT=true)
ADMIN_EMAIL=admin@sovereignml.com
ADMIN_PASSWORD=CHANGE_ME_FIRST_LOGIN
